{
  "name": "healthcheck",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "create:calculator": "bun run scripts/create-calculator.ts",
    "smoke": "playwright test e2e/calculators-all.spec.ts e2e/navigation.spec.ts e2e/fitness-age.spec.ts",
    "validate": "bun run format:check && bun run lint && bun run type-check && bun run test",
    "clean": "rm -rf .next out node_modules/.cache",
    "audit:fix": "npm audit fix",
    "update": "npm update",
    "prepare": "husky"
  },
  "keywords": [
    "health",
    "fitness",
    "calculator",
    "bmi",
    "body-fat",
    "tdee",
    "nutrition",
    "wellness",
    "next.js",
    "react"
  ],
  "author": "HealthCheck Team",
  "license": "UNLICENSED",
  "description": "Free health and fitness calculators for BMI, body fat, TDEE, and more. Built with Next.js, TypeScript, and TailwindCSS.",
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 113",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@radix-ui/react-radio-group": "^1.3.8",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-intersection-observer": "^10.0.3",
    "tailwind-merge": "^3.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "dompurify": ">=3.3.2",
    "flatted": ">=3.4.0",
    "minimatch": ">=3.1.3",
    "rollup": ">=4.59.0",
    "serialize-javascript": ">=7.0.3",
    "undici": ">=7.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.7",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
}
