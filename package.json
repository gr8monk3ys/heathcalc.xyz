{
  "name": "healthcheck",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "create:calculator": "bun run scripts/create-calculator.ts",
    "smoke": "playwright test e2e/calculators-all.spec.ts e2e/navigation.spec.ts e2e/fitness-age.spec.ts",
    "validate": "bun run format:check && bun run lint && bun run type-check && bun run test",
    "clean": "rm -rf .next out node_modules/.cache",
    "audit:fix": "npm audit fix",
    "update": "npm update",
    "prepare": "husky"
  },
  "keywords": [
    "health",
    "fitness",
    "calculator",
    "bmi",
    "body-fat",
    "tdee",
    "nutrition",
    "wellness",
    "next.js",
    "react"
  ],
  "author": "HealthCheck Team",
  "license": "UNLICENSED",
  "description": "Free health and fitness calculators for BMI, body fat, TDEE, and more. Built with Next.js, TypeScript, and TailwindCSS.",
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 113",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@radix-ui/react-radio-group": "^1.2.3",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.0.4",
    "@vercel/analytics": "^2.0.0",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "next": "^16.1.6",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-intersection-observer": "^10.0.2",
    "tailwind-merge": "^3.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.14",
    "baseline-browser-mapping": "^2.9.19",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "vite": "^8.0.0",
    "typescript": "^5.8.2",
    "@types/node": "^25.1.0",
    "vitest": "^4.0.8"
  }
}
